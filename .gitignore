# Environment / secrets
.env
.env.*
!.env.example

# Per-tenant setup config (contains real Tenant/Subscription/capacity IDs)
scripts/tenant.config.json
!scripts/tenant.config.example.json

# Node
node_modules/
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# VS Code local settings
.vscode/settings.json

# Data — block all CSVs by default (never commit real transaction data),
# but explicitly allow the 10 synthetic demo dataset files so the repo is
# self-contained for a fresh install (see data/README.txt).
data/*.csv
!data/Dim_Date.csv
!data/Dim_Client.csv
!data/Dim_Country.csv
!data/Dim_Product.csv
!data/Dim_Segment.csv
!data/Dim_Merchant.csv
!data/Dim_MCC.csv
!data/Dim_ApprovalStatus.csv
!data/Fact_CommercialSpend.csv
!data/Fact_FilterSession.csv

