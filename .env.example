# VISA PBIE Context Injection — environment variable template
# Copy to .env and fill in CLIENT_ID / CLIENT_SECRET from your Service Principal.

TENANT_ID=b7e47691-9726-4f67-a302-e567815f3522

# Service Principal credentials (required for embed token generation)
CLIENT_ID=<sp-client-id>
CLIENT_SECRET=<sp-client-secret>

# Fabric workspace (VISA PBIE Context Injection — confirmed 2026-07-21)
WORKSPACE_ID=349db6f1-5df6-4992-ba67-ebc4449fead5
DATASET_ID=b7bc94fc-a087-4e71-9476-f128ba57cf3a
REPORT_ID=e833a03b-2cf9-42d2-a1ee-a40f847fd75d
FABRIC_AGENT_ID=d2042f7c-989f-47d2-a3b4-92603f3e55ab
LAKEHOUSE_ID=1aa73044-f85f-4843-b3e5-588cab4c0499

# XMLA/RLS migration (Sprint 6+ / docs/design_notes.md Section 15) — set USE_XMLA=true
# to route DAX queries through the XMLA endpoint (scripts/query_xmla.ps1) instead of
# the executeQueries REST API, once the RLS functional test matrix has passed.
USE_XMLA=false
XMLA_ENDPOINT=powerbi://api.powerbi.com/v1.0/myorg/VISA PBIE Context Injection
# XMLA "Initial Catalog" requires the model's display NAME, not its GUID (DATASET_ID above is unusable here)
DATASET_NAME=Commercial_Spend_Analytics

# Server
PORT=3000

# Server-managed session (docs/design_notes.md §17) — signs the httpOnly session cookie
# that /api/session/login establishes. Required in production; a dev-only insecure
# default is used automatically if unset locally. Generate with e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=<random-32-byte-hex-string>

