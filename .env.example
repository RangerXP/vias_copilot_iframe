# VISA PBIE Context Injection — environment variable template
# Copy to .env and fill in CLIENT_ID / CLIENT_SECRET from your Service Principal.

TENANT_ID=b7e47691-9726-4f67-a302-e567815f3522

# Service Principal credentials (required for embed token generation)
CLIENT_ID=<sp-client-id>
CLIENT_SECRET=<sp-client-secret>

# Fabric workspace (VISA PBIE Context Injection — confirmed 2026-07-21)
WORKSPACE_ID=349db6f1-5df6-4992-ba67-ebc4449fead5
DATASET_ID=b7bc94fc-a087-4e71-9476-f128ba57cf3a
REPORT_ID=e833a03b-2cf9-42d2-a1ee-a40f847fd75d
FABRIC_AGENT_ID=d2042f7c-989f-47d2-a3b4-92603f3e55ab
LAKEHOUSE_ID=1aa73044-f85f-4843-b3e5-588cab4c0499

# Live Commercial_Spend_Agent Fabric Data Agent wiring (native, LLM-backed NL->DAX —
# see Commercial_Spend_Agent.DataAgent config + server/services/fabricAgent.js). Set
# USE_DATA_AGENT=true to route chat questions through the Data Agent's own published
# conversational endpoint instead of the fixed DAX_SHAPES/pickDax() path (deterministic
# path remains the automatic fallback on any failure). FABRIC_AGENT_ENDPOINT MUST be the
# *published* base URL — Fabric portal -> Commercial_Spend_Agent -> Publish -> Settings.
# This is not discoverable via the Fabric REST API; it must be captured manually.
USE_DATA_AGENT=false
FABRIC_AGENT_ENDPOINT=<published-data-agent-base-url>

# LLM orchestrator (server/services/llmOrchestrator.js, docs/design_notes.md Section 20)
# — an in-process Azure OpenAI chat-completions + function-calling layer whose only
# tool is the existing RLS-aware DAX-shape catalog (executeDax()/runXmlaQuery()). This
# is the recommended conversational path: it gets LLM-quality answers WITHOUT the
# native Fabric Data Agent's RLS gap, and without provisioning a full Azure AI Foundry
# Agent project. Requires an Azure OpenAI-capable Cognitive Services resource with a
# chat-completions model deployment that supports tool calling (e.g. gpt-4o), and the
# calling identity (CLIENT_ID above) granted the "Cognitive Services OpenAI User" role
# on that resource.
USE_LLM_ORCHESTRATOR=false
AOAI_ENDPOINT=<https://your-resource.cognitiveservices.azure.com/>
AOAI_DEPLOYMENT=<chat-completions-deployment-name>
AOAI_API_VERSION=2024-10-21

# XMLA/RLS migration (Sprint 6+ / docs/design_notes.md Section 15) — set USE_XMLA=true
# to route DAX queries through the XMLA endpoint (scripts/query_xmla.ps1) instead of
# the executeQueries REST API, once the RLS functional test matrix has passed.
USE_XMLA=false
XMLA_ENDPOINT=powerbi://api.powerbi.com/v1.0/myorg/VISA PBIE Context Injection
# XMLA "Initial Catalog" requires the model's display NAME, not its GUID (DATASET_ID above is unusable here)
DATASET_NAME=Commercial_Spend_Analytics

# Server
PORT=3000

# Server-managed session (docs/design_notes.md §17) — signs the httpOnly session cookie
# that /api/session/login establishes. Required in production; a dev-only insecure
# default is used automatically if unset locally. Generate with e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=<random-32-byte-hex-string>

